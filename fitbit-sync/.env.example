# =====================================================
# Google Health API (Fitbit Air) -> Firestore sync
# Copie ce fichier vers `.env` et remplis les valeurs.
# Ne JAMAIS commit le `.env` réel.
# =====================================================

# --- Firebase Admin SDK ---
# Chemin vers la clé de service (relatif au dossier fitbit-sync/).
# Tu peux réutiliser la même que coros-sync : copie coros-sync/service-account.json ici.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=fitness-373b6

# --- OAuth client Google (Console Google Cloud > Identifiants > ID client OAuth "Desktop") ---
# Récupérés dans le JSON téléchargé à la création du client OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Utilisateur cible dans Firestore ---
# Ton UID Firebase (Console > Authentication > Utilisateurs). Sinon BIOZ_USER_EMAIL.
BIOZ_USER_ID=
# BIOZ_USER_EMAIL=arnaud.hacquin@gmail.com

# --- Divers ---
TIMEZONE=Europe/Paris
SYNC_DAYS_WINDOW=14
