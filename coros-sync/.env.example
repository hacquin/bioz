# =====================================================
# Coros MCP -> Firestore sync — variables d'environnement
# Copie ce fichier vers `.env` et remplis les valeurs.
# Ne JAMAIS commit le `.env` réel.
# =====================================================

# --- Firebase Admin SDK ---
# Chemin vers la clé de service (relatif au dossier coros-sync/)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
FIREBASE_PROJECT_ID=fitness-373b6

# --- Coros MCP ---
COROS_MCP_ENDPOINT=https://mcpeu.coros.com/mcp
COROS_MCP_ISSUER=https://mcpeu.coros.com

# --- OAuth client (rempli par `npm run bootstrap`) ---
# Le bootstrap fait une Dynamic Client Registration auprès de Coros
# et écrit ces 2 valeurs dans .env automatiquement.
COROS_CLIENT_ID=
COROS_CLIENT_SECRET=

# --- Utilisateur cible dans Firestore ---
# Ton UID Firebase (Console > Authentication > Utilisateurs)
BIOZ_USER_ID=

# --- Divers ---
TIMEZONE=Europe/Paris
SYNC_DAYS_WINDOW=14
